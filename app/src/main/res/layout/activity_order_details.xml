<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_color">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 🔥 ORDER CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/bg_card_soft"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvOrderIdTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Order #12345"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accepted"
                android:textColor="@color/purple"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Items: Burger, Fries"
                android:textSize="15sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvLocations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Restaurant → Customer"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"/>

        </LinearLayout>

        <!-- 🚀 ACTION SECTION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 🗺️ Navigate Restaurant -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavigateRestaurant"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Navigate to Restaurant 🗺️"
                android:textAllCaps="false"
                android:backgroundTint="@android:color/white"
                android:textColor="@color/purple"
                app:strokeWidth="2dp"
                app:strokeColor="@color/purple"
                android:layout_marginBottom="10dp"/>

            <!-- 🟡 Reached -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReached"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Reached Restaurant"
                android:textAllCaps="false"
                android:backgroundTint="@color/purple"
                android:textColor="@android:color/white"
                android:layout_marginBottom="10dp"/>

            <!-- 🟠 Picked -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickedUp"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Picked Up Order"
                android:textAllCaps="false"
                android:backgroundTint="@color/purple"
                android:textColor="@android:color/white"
                android:layout_marginBottom="10dp"/>

            <!-- 🗺️ Navigate Customer -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavigateCustomer"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Navigate to Customer 🗺️"
                android:textAllCaps="false"
                android:backgroundTint="@android:color/white"
                android:textColor="@color/purple"
                app:strokeWidth="2dp"
                app:strokeColor="@color/purple"
                android:layout_marginBottom="10dp"/>

            <!-- 🔵 Out -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOut"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Out for Delivery"
                android:textAllCaps="false"
                android:backgroundTint="@color/purple"
                android:textColor="@android:color/white"
                android:layout_marginBottom="10dp"/>

            <!-- 🟢 Delivered -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelivered"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Mark as Delivered"
                android:textAllCaps="false"
                android:backgroundTint="@color/orange_accent"
                android:textColor="@android:color/white"/>

        </LinearLayout>

        <!-- ⏳ LOADER -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_marginTop="20dp"/>

    </LinearLayout>

</ScrollView>