<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/surface_color">

    <TextView
        android:id="@+id/tvOrderIdTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Order Details"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="?attr/colorPrimary"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Items: 2x Burger, 1x Fries"
        android:textSize="18sp"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvLocations"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pickup: Res A \nDrop: Cust B"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="32dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnReached"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Reached Restaurant"
        android:backgroundTint="?attr/colorPrimary"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPickedUp"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Picked Up"
        android:backgroundTint="?attr/colorPrimary"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOut"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Out for Delivery"
        android:backgroundTint="?attr/colorPrimary"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDelivered"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Delivered"
        android:backgroundTint="@color/orange_accent" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:layout_marginTop="16dp" />

</LinearLayout>
