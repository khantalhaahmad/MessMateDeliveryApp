<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- 🔥 HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp"
                android:padding="8dp">

                <!-- LEFT CONTENT (PRO HEADER) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Greeting (Primary) -->
                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome Back 👋"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:letterSpacing="0.02"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="4dp"/>

                    <!-- Location Row (Icon + Text aligned) -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Location Icon -->
                        <!-- Location Icon -->
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_location"
                            android:tint="@color/primary"
                            android:layout_marginEnd="4dp"/>

                        <!-- Location Text -->
                        <TextView
                            android:id="@+id/tvLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nayapalli, Bhubaneswar"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:maxLines="1"
                            android:ellipsize="end"/>
                    </LinearLayout>

                </LinearLayout>


                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchOnline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- 💰 EARNINGS CARD (PREMIUM) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                android:layout_marginBottom="24dp"
                android:backgroundTint="@color/purple_primary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Today's Earnings"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:alpha="0.8"/>

                    <TextView
                        android:id="@+id/tvEarnings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹0"
                        android:textColor="@android:color/white"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 📊 WEEKLY GRAPH -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="6dp"
                android:layout_marginBottom="20dp">

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chart"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:padding="12dp"/>

            </com.google.android.material.card.MaterialCardView>

            <!-- 📦 SECTION TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Active Delivery"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="10dp"
                android:drawableStart="@android:drawable/ic_menu_mylocation"
                android:drawablePadding="6dp"/>

            <!-- ⏳ WAITING STATE -->
            <LinearLayout
                android:id="@+id/viewWaiting"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:gravity="center"
                android:orientation="vertical"
                android:background="@drawable/bg_card_soft"
                android:padding="20dp">

                <ProgressBar
                    android:id="@+id/pbWaiting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminateTint="@color/purple_primary"/>

                <TextView
                    android:id="@+id/tvWaitingMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Waiting for new orders..."
                    android:textSize="15sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="12dp"
                    android:alpha="0.8"/>
            </LinearLayout>


            <!-- 🚀 ACTIVE ORDER CARD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOrder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                android:visibility="gone"
                android:layout_marginTop="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:orientation="vertical">

                    <!-- 🍽️ Restaurant Name -->
                    <TextView
                        android:id="@+id/tvOrderMessName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Restaurant"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <!-- 💰 Fee -->
                    <TextView
                        android:id="@+id/tvOrderFee"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹50"
                        android:textSize="15sp"
                        android:textColor="@color/orange_accent"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="10dp"/>
                    <!-- 👤 CUSTOMER NAME -->
                    <TextView
                        android:id="@+id/tvCustomerName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Customer Name"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="6dp"/>

                    <!-- 📞 PHONE -->
                    <TextView
                        android:id="@+id/tvCustomerPhone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phone"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"/>

                    <!-- 💳 PAYMENT -->
                    <TextView
                        android:id="@+id/tvPayment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="COD"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/purple_primary"
                        android:layout_marginTop="6dp"/>

                    <!-- 📍 Pickup -->
                    <TextView
                        android:id="@+id/tvPickupLoc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍 Pickup Location"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"/>

                    <!-- 🏁 Drop -->
                    <TextView
                        android:id="@+id/tvDropLoc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏁 Drop Location"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="6dp"/>

                    <!-- 📏 Distance -->
                    <TextView
                        android:id="@+id/tvDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Distance: -- km"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="@color/purple_primary"
                        android:layout_marginTop="8dp"/>

                    <!-- ⏱️ TIMER -->
                    <TextView
                        android:id="@+id/tvTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="15s"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/holo_red_dark"
                        android:layout_marginTop="6dp"/>

                    <!-- 🚀 Action Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOrderAction"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Accept Order"
                        android:textSize="15sp"
                        android:textAllCaps="false"
                        android:layout_marginTop="16dp"
                        android:backgroundTint="@color/orange_accent"
                        app:cornerRadius="12dp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>