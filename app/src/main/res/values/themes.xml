<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- 🌟 APP THEME (Material3 REQUIRED) -->
    <style name="Theme.MessMateDelivery" parent="Theme.Material3.Light.NoActionBar">

        <!-- Primary -->
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary (used for indicator color 🔥) -->
        <item name="colorSecondary">#1565C0</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">?attr/colorPrimary</item>

    </style>


    <!-- 🔥 ACTIVE INDICATOR (ZOMATO STYLE CIRCLE) -->
    <style name="ActiveIndicatorStyle">
        <item name="materialThemeOverlay">@style/IndicatorOverlay</item>
        <item name="shapeAppearance">@style/IndicatorShape</item>
    </style>


    <!-- 🎯 Indicator Color Control -->
    <style name="IndicatorOverlay">
        <item name="colorSecondary">#1565C0</item>
    </style>


    <!-- 🔵 Circle Shape -->
    <style name="IndicatorShape">
        <item name="cornerSize">50%</item>
    </style>

</resources>